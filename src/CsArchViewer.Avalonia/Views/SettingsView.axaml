<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CsArchViewer.Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="CsArchViewer.Avalonia.Views.SettingsView"
             x:DataType="vm:MainWindowViewModel">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="20" MaxWidth="720">
      <TextBlock Text="{Binding SettingsTitleText}"
                 FontSize="22"
                 FontWeight="SemiBold"
                 Foreground="#E2E8F0" />
      <TextBlock Text="{Binding SettingsDescriptionText}"
                 Foreground="#94A3B8"
                 TextWrapping="Wrap" />
      <Border Background="#0F172A"
              BorderBrush="#2E3748"
              BorderThickness="1"
              CornerRadius="6"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding GraphSectionText}"
                     FontWeight="SemiBold"
                     Foreground="#CBD5E1" />
          <CheckBox Content="{Binding ShowLineCountText}"
                    IsChecked="{Binding ShowLineCountOnNodes, Mode=TwoWay}"
                    Foreground="#E2E8F0" />

          <TextBlock Text="{Binding ThemeText}"
                     FontWeight="SemiBold"
                     Foreground="#CBD5E1"
                     Margin="0,8,0,0" />
          <ComboBox Width="220"
                    ItemsSource="{Binding AvailableThemeOptions}"
                    SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />

          <TextBlock Text="{Binding GraphLayoutText}"
                     FontWeight="SemiBold"
                     Foreground="#CBD5E1"
                     Margin="0,8,0,0" />
          <ComboBox Width="220"
                    ItemsSource="{Binding AvailableGraphLayoutOptions}"
                    SelectedItem="{Binding SelectedGraphLayout, Mode=TwoWay}" />

          <TextBlock Text="{Binding OverlayModeText}"
                     FontWeight="SemiBold"
                     Foreground="#CBD5E1"
                     Margin="0,8,0,0" />
          <ComboBox Width="220"
                    ItemsSource="{Binding AvailableOverlayModes}"
                    SelectedItem="{Binding SelectedOverlayMode, Mode=TwoWay}" />

          <TextBlock Text="{Binding LanguageText}"
                     FontWeight="SemiBold"
                     Foreground="#CBD5E1"
                     Margin="0,8,0,0" />
          <ComboBox Width="200"
                    ItemsSource="{Binding AvailableLanguages}"
                    SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}" />

          <CheckBox Content="{Binding RestoreLastSessionText}"
                    IsChecked="{Binding RestoreLastSession, Mode=TwoWay}"
                    Foreground="#E2E8F0"
                    Margin="0,8,0,0" />
          <CheckBox Content="{Binding AutoSaveSessionText}"
                    IsChecked="{Binding AutoSaveSession, Mode=TwoWay}"
                    Foreground="#E2E8F0" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
