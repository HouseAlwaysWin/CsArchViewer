<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:CsArchViewer.Avalonia.Views"
        xmlns:conv="clr-namespace:CsArchViewer.Avalonia.Converters"
        xmlns:vm="clr-namespace:CsArchViewer.Avalonia.ViewModels"
        xmlns:core="clr-namespace:CsArchViewer.Core.Models;assembly=CsArchViewer.Core"
        xmlns:diag="clr-namespace:CsArchViewer.Diagnostics;assembly=CsArchViewer.Diagnostics"
        xmlns:symexp="clr-namespace:CsArchViewer.DotNet.SymbolExplorer.Models;assembly=CsArchViewer.DotNet.SymbolExplorer"
        mc:Ignorable="d"
        d:DesignWidth="1400"
        d:DesignHeight="820"
        x:Class="CsArchViewer.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Title="CsArchViewer - .NET Architecture Viewer"
        Icon="/Assets/Icons/logo-mark.png">
  <Window.Resources>
    <conv:DiagnosticSeverityBrushConverter x:Key="DiagnosticSeverityBrushConverter" />
    <conv:ExplorerSymbolKindBrushConverter x:Key="ExplorerSymbolKindBrushConverter" />
  </Window.Resources>
  <DockPanel>
    <TabControl Margin="0"
                Padding="0"
                TabStripPlacement="Top"
                Background="{DynamicResource AppWindowBackgroundBrush}">
      <TabItem Header="{Binding WorkspaceTabText}" FontWeight="SemiBold" FontSize="14" Padding="14,8">
        <DockPanel>
          <Border DockPanel.Dock="Top"
                  Padding="10,8"
                  BorderBrush="{DynamicResource AppBorderBrush}"
                  BorderThickness="0,0,0,1"
                  Background="{DynamicResource AppWindowBackgroundBrush}">
            <DockPanel LastChildFill="True">
              <!-- Top-edge loading indicator line -->
              <ProgressBar DockPanel.Dock="Top"
                           Height="4"
                           Margin="0,-8,0,6"
                           IsIndeterminate="True"
                           IsVisible="{Binding IsAnalyzing}"
                           Foreground="#60A5FA"
                           HorizontalAlignment="Stretch" />

              <WrapPanel DockPanel.Dock="Top"
                         Orientation="Horizontal"
                         VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,6">
                  <Button Content="{Binding OpenFolderText}" Click="OpenFolder_OnClick" />
                  <Button Content="{Binding ReloadText}" Click="Reload_OnClick" />
                  <Separator Width="1" Height="22" Margin="4,0" Background="{DynamicResource AppBorderBrush}" />
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <ComboBox x:Name="ExportFormatCombo"
                              Width="150"
                              SelectedIndex="0"
                              SelectionChanged="ExportFormatCombo_OnSelectionChanged">
                      <ComboBoxItem Content="Mermaid" />
                      <ComboBoxItem Content="JSON" />
                      <ComboBoxItem Content="DOT" />
                      <ComboBoxItem Content="AI Prompt" />
                      <ComboBoxItem Content="Metrics JSON" />
                      <ComboBoxItem Content="Metrics CSV" />
                      <ComboBoxItem Content="Metrics Markdown" />
                    </ComboBox>
                    <Button x:Name="ExportActionButton"
                            Content="{Binding ExportText}"
                            Click="Export_OnClick" />
                  </StackPanel>
                  <Separator Width="1" Height="22" Margin="4,0" Background="{DynamicResource AppBorderBrush}" />
                   <ComboBox Width="190"
                             ItemsSource="{Binding AvailableGraphTypes}"
                             SelectedItem="{Binding SelectedGraphType, Mode=TwoWay}" />
                   <TextBlock VerticalAlignment="Center"
                              Foreground="{DynamicResource AppSecondaryTextBrush}"
                              Text="{Binding GroupByText}" />
                   <ComboBox Width="130"
                             ItemsSource="{Binding AvailableGroupingModes}"
                             SelectedItem="{Binding SelectedGroupingMode, Mode=TwoWay}" />
                   <Button Content="{Binding FitToScreenText}"
                           Click="FitToScreen_OnClick" />
                   <Button Content="{Binding ZoomToSelectionText}"
                           Click="ZoomToSelection_OnClick" />
                   <ComboBox Width="130"
                             ItemsSource="{Binding AvailableTypeFilters}"
                             SelectedItem="{Binding SelectedTypeFilter, Mode=TwoWay}" />
                  <Separator Width="1" Height="22" Margin="4,0" Background="{DynamicResource AppBorderBrush}" />
                  <TextBox Width="280"
                           VerticalAlignment="Center"
                           PlaceholderText="{Binding SearchPlaceholderText}"
                           Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
              </WrapPanel>

              <TextBlock DockPanel.Dock="Top"
                         Margin="0,4,0,0"
                         Foreground="{DynamicResource AppTertiaryTextBrush}"
                         FontSize="12"
                         Text="{Binding TopStatus}"
                         TextWrapping="Wrap" />
              <TextBlock DockPanel.Dock="Top"
                         Margin="0,2,0,0"
                         Foreground="{DynamicResource AppAccentTextBrush}"
                         FontSize="11"
                         Text="{Binding PerformanceStatusText}"
                         TextWrapping="Wrap" />
            </DockPanel>
          </Border>

          <Grid x:Name="DiagnosticsLayoutGrid" MinHeight="200">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="6" />
              <RowDefinition Height="180" />
            </Grid.RowDefinitions>
          <Grid Grid.Row="0"
                ColumnDefinitions="260,6,*,6,300"
                MinHeight="120">
            <Border Grid.Column="0"
                    MinWidth="160"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,1,0">
              <TabControl Margin="4">
                <TabItem Header="{Binding NodesTitleText}" FontWeight="SemiBold" FontSize="14">
                  <DockPanel LastChildFill="True">
                    <ListBox Margin="6"
                             ItemsSource="{Binding ListedNodes}"
                             SelectedItem="{Binding SelectedListedNode, Mode=TwoWay}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="core:ArchitectureNode">
                          <StackPanel Margin="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                            <TextBlock FontSize="11" Foreground="{DynamicResource AppTertiaryTextBrush}" Text="{Binding Type}" />
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </DockPanel>
                </TabItem>
                <TabItem Header="{Binding SymbolExplorerTabText}" FontWeight="SemiBold" FontSize="14">
                  <DockPanel LastChildFill="True">
                    <DockPanel DockPanel.Dock="Top"
                               Margin="8,8,8,4"
                               LastChildFill="True">
                      <Button DockPanel.Dock="Right"
                              Margin="8,0,0,0"
                              Padding="10,4"
                              Content="{Binding SymbolExplorerSearchButtonText}"
                              Click="SymbolExplorerSearch_OnClick" />
                      <TextBox VerticalAlignment="Center"
                               PlaceholderText="{Binding SymbolExplorerSearchPlaceholderText}"
                               Text="{Binding SymbolExplorerSearchQuery}" />
                    </DockPanel>
                    <ListBox Margin="8,0,8,8"
                             ItemsSource="{Binding SymbolExplorerResults}"
                             SelectedItem="{Binding SelectedExplorerSymbol, Mode=TwoWay}"
                             SelectionChanged="SymbolExplorerResults_OnSelectionChanged">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="symexp:SymbolInfoModel">
                          <StackPanel Margin="2">
                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Kind, Converter={StaticResource ExplorerSymbolKindBrushConverter}}"
                                       Text="{Binding Kind}" />
                            <TextBlock FontSize="10" Foreground="{DynamicResource AppQuaternaryTextBrush}" Text="{Binding Namespace}" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </DockPanel>
                </TabItem>
              </TabControl>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          Background="{DynamicResource AppSplitterBrush}"
                          ResizeDirection="Columns" />

            <Border Grid.Column="2" MinWidth="200" Background="{DynamicResource AppSurfaceBackgroundBrush}">
              <Grid RowDefinitions="Auto,*">
                <views:GraphLegendView />
                <views:GraphView x:Name="GraphViewControl"
                                 Grid.Row="1"
                                 DataContext="{Binding Graph}" />
              </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          Background="{DynamicResource AppSplitterBrush}"
                          ResizeDirection="Columns" />

            <Border Grid.Column="4"
                    MinWidth="200"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1,0,0,0">
                <TabControl>
                  <TabItem Header="{Binding NodeDetailsTitleText}" FontWeight="SemiBold" FontSize="14">
                    <views:NodeDetailsSummaryView />
                  </TabItem>
                <TabItem Header="{Binding SymbolExplorerDetailsTabText}" FontWeight="SemiBold" FontSize="14">
                  <ScrollViewer>
                    <StackPanel Margin="10" Spacing="8">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{Binding SymbolExplorerFindRefsText}"
                                Click="SymbolExplorerFindRefs_OnClick" />
                        <Button Content="{Binding SymbolExplorerGoToDefText}"
                                Click="SymbolExplorerGoToDef_OnClick" />
                        <Border Padding="8,2"
                                CornerRadius="999"
                                BorderThickness="1"
                                BorderBrush="{Binding SelectedExplorerSymbol.Kind, Converter={StaticResource ExplorerSymbolKindBrushConverter}}">
                          <TextBlock FontWeight="SemiBold"
                                     Foreground="{Binding SelectedExplorerSymbol.Kind, Converter={StaticResource ExplorerSymbolKindBrushConverter}}"
                                     Text="{Binding SelectedExplorerSymbol.Kind}" />
                        </Border>
                      </StackPanel>
                      <TextBlock FontWeight="SemiBold"
                                 FontSize="14"
                                 Foreground="{Binding SelectedExplorerSymbol.Kind, Converter={StaticResource ExplorerSymbolKindBrushConverter}}"
                                 Text="{Binding ExplorerSymbolTitle}" />
                      <Border Padding="10"
                              CornerRadius="6"
                              BorderBrush="{DynamicResource AppBorderBrush}"
                              BorderThickness="1"
                              Background="{DynamicResource AppSurfaceAltBackgroundBrush}">
                        <TextBox IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Text="{Binding ExplorerSymbolDetailsText}"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 LineHeight="18"
                                 Foreground="{DynamicResource AppSecondaryTextBrush}" />
                      </Border>
                      <Separator Background="{DynamicResource AppBorderBrush}"
                                 Margin="0,2,0,2" />
                      <TextBlock FontWeight="Bold"
                                 Text="{Binding SymbolExplorerTypeMembersTitleText}" />
                      <TextBlock FontWeight="SemiBold"
                                 FontSize="13"
                                 Foreground="{Binding SelectedExplorerSymbol.Kind, Converter={StaticResource ExplorerSymbolKindBrushConverter}}"
                                 Text="{Binding ExplorerTypeTitle}" />
                      <Border Padding="10"
                              CornerRadius="6"
                              BorderBrush="{DynamicResource AppBorderBrush}"
                              BorderThickness="1"
                              Background="{DynamicResource AppSurfaceAltBackgroundBrush}">
                        <TextBox IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Text="{Binding ExplorerTypeMembersSummary}"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 LineHeight="17"
                                 Foreground="{DynamicResource AppTertiaryTextBrush}" />
                      </Border>
                      <ListBox MaxHeight="160"
                               ItemsSource="{Binding ExplorerTypeProperties}">
                        <ListBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:ExplorerPropertyDisplayItem">
                            <TextBlock FontFamily="Consolas"
                                       FontSize="11">
                              <Run Text="· "
                                   Foreground="#64748B" />
                              <Run Text="{Binding Name}"
                                   Foreground="#F8FAFC" />
                              <Run Text=" : "
                                   Foreground="#64748B" />
                              <Run Text="{Binding Type}"
                                   Foreground="#38BDF8" />
                            </TextBlock>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                      <ListBox Height="220"
                               ItemsSource="{Binding ExplorerTypeMethods}"
                               SelectedItem="{Binding SelectedExplorerMethod, Mode=TwoWay}"
                               SelectionChanged="ExplorerMethods_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                          <DataTemplate x:DataType="symexp:MethodInfoModel">
                            <StackPanel Margin="2"
                                        Spacing="2">
                              <TextBlock FontWeight="SemiBold">
                                <Run Text="{Binding Name}"
                                     Foreground="#F8FAFC" />
                                <Run Text=" : "
                                     Foreground="#64748B" />
                                <Run Text="{Binding ReturnType}"
                                     Foreground="#F59E0B" />
                              </TextBlock>
                              <TextBlock FontSize="11"
                                         Foreground="{DynamicResource AppTertiaryTextBrush}"
                                         Text="{Binding Signature}"
                                         TextWrapping="Wrap" />
                              <TextBlock FontSize="10"
                                         Foreground="{DynamicResource AppQuaternaryTextBrush}"
                                         Text="{Binding Accessibility}" />
                            </StackPanel>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                      <TextBlock FontWeight="Bold"
                                 Text="{Binding SymbolExplorerMethodMetaTitleText}" />
                      <Border Padding="10"
                              CornerRadius="6"
                              BorderBrush="{DynamicResource AppBorderBrush}"
                              BorderThickness="1"
                              Background="{DynamicResource AppSurfaceAltBackgroundBrush}">
                        <TextBox IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Text="{Binding ExplorerMethodMetadataText}"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 LineHeight="17" />
                      </Border>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>
              </TabControl>
            </Border>
          </Grid>

          <GridSplitter Grid.Row="1"
                        x:Name="DiagnosticsSplitter"
                        Height="6"
                        DoubleTapped="DiagnosticsSplitter_OnDoubleTapped"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                         Background="{DynamicResource AppSplitterBrush}"
                        ResizeDirection="Rows" />

          <Border Grid.Row="2"
                  BorderBrush="{DynamicResource AppBorderBrush}"
                  BorderThickness="0,1,0,0"
                  Padding="8"
                  Background="{DynamicResource AppWindowBackgroundBrush}">
            <TabControl>
              <TabItem Header="{Binding BottomPanelDiagnosticsTabText}" FontWeight="SemiBold" FontSize="13">
             <Grid ColumnDefinitions="2*,6,*" RowDefinitions="Auto,*">
              <DockPanel LastChildFill="False">
                <Button x:Name="DiagnosticsToggleButton"
                        DockPanel.Dock="Left"
                        Width="24"
                        Height="20"
                        Padding="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Content="▾"
                        Click="DiagnosticsToggleButton_OnClick" />
                <TextBlock DockPanel.Dock="Left"
                           Margin="6,0,0,0"
                           Text="{Binding DiagnosticsTitleText}"
                           FontWeight="Bold" />
                <ComboBox DockPanel.Dock="Right"
                          Width="140"
                          Margin="8,0,0,0"
                          ItemsSource="{Binding AvailableDiagnosticsSeverityOptions}"
                          SelectedItem="{Binding SelectedDiagnosticsSeverityFilter, Mode=TwoWay}" />
                <Button DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Content="{Binding ExportDiagnosticsText}"
                        Click="ExportDiagnostics_OnClick" />
               </DockPanel>
              <ListBox Grid.Row="1"
                       Margin="0,8,0,0"
                       ItemsSource="{Binding FilteredDiagnostics}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="diag:ArchitectureDiagnostic">
                    <Border Margin="0,0,0,8"
                            Padding="10"
                            CornerRadius="6"
                            BorderBrush="{Binding Severity, Converter={StaticResource DiagnosticSeverityBrushConverter}}"
                            BorderThickness="4,0,0,0"
                            Background="{DynamicResource AppSurfaceAltBackgroundBrush}">
                      <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <Border Padding="8,2"
                                  CornerRadius="999"
                                  Background="{Binding Severity, Converter={StaticResource DiagnosticSeverityBrushConverter}, ConverterParameter=Background}">
                            <TextBlock Text="{Binding Severity}"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Severity, Converter={StaticResource DiagnosticSeverityBrushConverter}, ConverterParameter=Foreground}" />
                          </Border>
                          <TextBlock Text="{Binding Type}"
                                     FontWeight="SemiBold"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding Source}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppTertiaryTextBrush}" />
                        <TextBlock Text="{Binding Target}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppQuaternaryTextBrush}" />
                        <TextBlock Text="{Binding Message}"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding Severity, Converter={StaticResource DiagnosticSeverityBrushConverter}}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <GridSplitter Grid.Column="1"
                            Grid.RowSpan="2"
                            Width="6"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="{DynamicResource AppSplitterBrush}"
                            ResizeDirection="Columns" />

              <TextBlock Grid.Column="2"
                         Text="{Binding TopFilesByLineCountText}"
                         FontWeight="Bold"
                         Margin="12,0,0,0" />
              <ListBox Grid.Row="1"
                       Grid.Column="2"
                       Margin="12,8,0,0"
                       ItemsSource="{Binding TopFilesByLineCount}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Spacing="2" Margin="2">
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding FileName}" />
                      <TextBlock Foreground="{DynamicResource AppTertiaryTextBrush}"
                                 Text="{Binding FilePath}"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                 Text="{Binding LineCount, StringFormat={}{0} lines}" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
               </TabItem>
               <TabItem Header="{Binding DependencyPathTabText}" FontWeight="SemiBold" FontSize="13">
                 <DockPanel LastChildFill="True">
                   <StackPanel DockPanel.Dock="Top"
                               Spacing="8"
                               Margin="0,0,0,8">
                     <TextBlock Text="{Binding DependencyPathSourceTextLabel}"
                                FontWeight="Bold" />
                     <TextBlock Text="{Binding DependencyPathSourceText}"
                                Foreground="{DynamicResource AppSecondaryTextBrush}"
                                TextWrapping="Wrap" />
                     <TextBlock Text="{Binding DependencyPathTargetTextLabel}"
                                FontWeight="Bold" />
                     <TextBox Text="{Binding DependencyPathTargetQuery, Mode=TwoWay}" />
                     <StackPanel Orientation="Horizontal" Spacing="8">
                       <Button Content="{Binding DependencyPathShortestText}"
                               Click="DependencyPathShortest_OnClick" />
                       <Button Content="{Binding DependencyPathCycleText}"
                               Click="DependencyPathCycle_OnClick" />
                     </StackPanel>
                     <TextBlock Text="{Binding DependencyPathSummaryText}"
                                Foreground="{DynamicResource AppAccentTextBrush}"
                                TextWrapping="Wrap" />
                   </StackPanel>
                   <Grid ColumnDefinitions="2*,*" RowDefinitions="Auto,*">
                     <TextBlock Text="{Binding DependencyPathTabText}"
                                FontWeight="Bold" />
                     <TextBlock Grid.Column="1"
                                Margin="12,0,0,0"
                                Text="{Binding RecentSearchesText}"
                                FontWeight="Bold" />
                     <ListBox Grid.Row="1"
                              Margin="0,8,6,0"
                              ItemsSource="{Binding DependencyPathSteps}" />
                     <ListBox Grid.Row="1"
                              Grid.Column="1"
                              Margin="6,8,0,0"
                              ItemsSource="{Binding RecentSearches}" />
                   </Grid>
                 </DockPanel>
               </TabItem>
               <TabItem Header="{Binding SymbolExplorerReferencesTabText}" FontWeight="SemiBold" FontSize="13">
                 <DockPanel LastChildFill="True">
                   <StackPanel DockPanel.Dock="Top"
                              Orientation="Horizontal"
                              Spacing="8"
                              Margin="0,0,0,8">
                    <Button Content="{Binding SymbolExplorerJumpOpenText}"
                            Click="ExplorerReferencesOpen_OnClick" />
                  </StackPanel>
                  <ListBox ItemsSource="{Binding ExplorerReferences}"
                           SelectedItem="{Binding SelectedExplorerReference, Mode=TwoWay}"
                           DoubleTapped="ExplorerReferences_OnDoubleTapped">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="symexp:ReferenceInfoModel">
                        <StackPanel Margin="2" Spacing="2">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding ReferencingSymbolDisplay}"
                                     TextWrapping="Wrap" />
                          <TextBlock FontSize="11"
                                     Foreground="{DynamicResource AppTertiaryTextBrush}"
                                     Text="{Binding FilePath}"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock FontSize="11"
                                     Foreground="{DynamicResource AppQuaternaryTextBrush}"
                                     Text="{Binding LineNumber, StringFormat=Line {0}}" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                   </ListBox>
                 </DockPanel>
               </TabItem>
               <TabItem Header="{Binding LogsTabText}" FontWeight="SemiBold" FontSize="13">
                 <DockPanel LastChildFill="True">
                   <TextBlock DockPanel.Dock="Top"
                              Margin="0,0,0,8"
                              Foreground="{DynamicResource AppAccentTextBrush}"
                              Text="{Binding PerformanceStatusText}"
                              TextWrapping="Wrap" />
                   <ListBox ItemsSource="{Binding LogEntries}">
                     <ListBox.ItemTemplate>
                       <DataTemplate x:DataType="core:AppLogEntry">
                         <StackPanel Margin="2" Spacing="2">
                           <StackPanel Orientation="Horizontal" Spacing="6">
                             <TextBlock FontWeight="SemiBold"
                                        Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                             <TextBlock FontWeight="SemiBold"
                                        Text="{Binding Level}" />
                             <TextBlock FontWeight="SemiBold"
                                        Text="{Binding Category}" />
                           </StackPanel>
                           <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                      Text="{Binding Message}"
                                      TextWrapping="Wrap" />
                         </StackPanel>
                       </DataTemplate>
                     </ListBox.ItemTemplate>
                   </ListBox>
                 </DockPanel>
               </TabItem>
             </TabControl>
           </Border>
        </Grid>
        </DockPanel>
      </TabItem>
      <TabItem Header="{Binding MetricsTabText}" FontWeight="SemiBold" FontSize="14" Padding="14,8">
        <views:MetricsDashboardView />
      </TabItem>
      <TabItem Header="{Binding SettingsTabText}" FontWeight="SemiBold" FontSize="14" Padding="14,8">
        <views:SettingsView />
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
