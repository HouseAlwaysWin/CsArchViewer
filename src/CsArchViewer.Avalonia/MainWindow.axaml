<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:CsArchViewer.Avalonia.Views"
        xmlns:vm="clr-namespace:CsArchViewer.Avalonia.ViewModels"
        xmlns:core="clr-namespace:CsArchViewer.Core.Models;assembly=CsArchViewer.Core"
        mc:Ignorable="d"
        d:DesignWidth="1400"
        d:DesignHeight="820"
        x:Class="CsArchViewer.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CsArchViewer - .NET Architecture Viewer">
  <DockPanel>
    <TabControl Margin="0"
                Padding="0"
                TabStripPlacement="Top"
                Background="#0B1220">
      <TabItem Header="{Binding WorkspaceTabText}" FontWeight="SemiBold" Padding="14,8">
        <DockPanel>
          <Border DockPanel.Dock="Top"
                  Padding="10,8"
                  BorderBrush="#2E3748"
                  BorderThickness="0,0,0,1"
                  Background="#0B1220">
            <DockPanel LastChildFill="True">
              <!-- Top-edge loading indicator line -->
              <ProgressBar DockPanel.Dock="Top"
                           Height="4"
                           Margin="0,-8,0,6"
                           IsIndeterminate="True"
                           IsVisible="{Binding IsAnalyzing}"
                           Foreground="#60A5FA"
                           HorizontalAlignment="Stretch" />

              <WrapPanel DockPanel.Dock="Top"
                         Orientation="Horizontal"
                         VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,6">
                  <Button Content="{Binding OpenFolderText}" Click="OpenFolder_OnClick" />
                  <Button Content="{Binding ReloadText}" Click="Reload_OnClick" />
                  <Separator Width="1" Height="22" Margin="4,0" Background="#2E3748" />
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <ComboBox x:Name="ExportFormatCombo"
                              Width="150"
                              SelectedIndex="0">
                      <ComboBoxItem Content="Mermaid" />
                      <ComboBoxItem Content="JSON" />
                      <ComboBoxItem Content="DOT" />
                    </ComboBox>
                    <Button Content="{Binding ExportText}" Click="Export_OnClick" />
                  </StackPanel>
                  <Separator Width="1" Height="22" Margin="4,0" Background="#2E3748" />
                  <ComboBox Width="190"
                            ItemsSource="{Binding AvailableGraphTypes}"
                            SelectedItem="{Binding SelectedGraphType, Mode=TwoWay}" />
                  <ComboBox Width="130"
                            ItemsSource="{Binding AvailableTypeFilters}"
                            SelectedItem="{Binding SelectedTypeFilter, Mode=TwoWay}" />
                  <Separator Width="1" Height="22" Margin="4,0" Background="#2E3748" />
                  <TextBox Width="280"
                           VerticalAlignment="Center"
                           PlaceholderText="{Binding SearchPlaceholderText}"
                           Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
              </WrapPanel>

              <TextBlock DockPanel.Dock="Top"
                         Margin="0,4,0,0"
                         Foreground="#94A3B8"
                         FontSize="12"
                         Text="{Binding TopStatus}"
                         TextWrapping="Wrap" />
            </DockPanel>
          </Border>

          <Grid x:Name="DiagnosticsLayoutGrid" MinHeight="200">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="6" />
              <RowDefinition Height="180" />
            </Grid.RowDefinitions>
          <Grid Grid.Row="0"
                ColumnDefinitions="260,6,*,6,300"
                MinHeight="120">
            <Border Grid.Column="0"
                    MinWidth="160"
                    BorderBrush="#2E3748"
                    BorderThickness="0,0,1,0">
              <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           FontWeight="Bold"
                           Margin="10,10,10,4"
                           Text="{Binding NodesTitleText}" />
                <ListBox Margin="10,0,10,10"
                         ItemsSource="{Binding ListedNodes}"
                         SelectedItem="{Binding SelectedListedNode, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="core:ArchitectureNode">
                      <StackPanel Margin="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                        <TextBlock FontSize="11" Foreground="#94A3B8" Text="{Binding Type}" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          Background="#1E293B"
                          ResizeDirection="Columns" />

            <Border Grid.Column="2" MinWidth="200" Background="#111827">
              <Grid RowDefinitions="Auto,*">
                <Border Background="#0F172A"
                        BorderBrush="#1E293B"
                        BorderThickness="0,0,0,1"
                        Padding="8">
                  <WrapPanel Orientation="Horizontal" ItemHeight="18" ItemWidth="120">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#1F2937" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Library" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#065F46" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Exe / WinExe" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#4C1D95" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Folder" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#334155" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="File" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#7C2D12" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Solution" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#14B8A6" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Package" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#0F766E" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Namespace" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#B91C1C" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Violation" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#1D4ED8" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Type" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#38BDF8" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Interface" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#7C3AED" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Struct" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#BE185D" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Enum" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14" Background="#10B981" CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Record" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Width="14" Height="14"
                              BorderBrush="#F59E0B"
                              BorderThickness="2"
                              CornerRadius="3" />
                      <TextBlock VerticalAlignment="Center" Foreground="#CBD5E1" Text="Search Hit" />
                    </StackPanel>
                  </WrapPanel>
                </Border>
                <views:GraphView x:Name="GraphViewControl"
                                 Grid.Row="1"
                                 DataContext="{Binding Graph}" />
              </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          Background="#1E293B"
                          ResizeDirection="Columns" />

            <Border Grid.Column="4"
                    MinWidth="200"
                    BorderBrush="#2E3748"
                    BorderThickness="1,0,0,0">
              <ScrollViewer>
                <StackPanel Margin="10" Spacing="8">
                  <TextBlock FontWeight="Bold" Text="{Binding NodeDetailsTitleText}" />
                  <TextBlock Text="{Binding ProjectNameText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.ProjectName}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding NodeTypeText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.NodeType}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding FullPathText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.FullPath}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding TargetFrameworkText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.TargetFramework}" />
                  <TextBlock Text="{Binding OutputTypeText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.OutputType}" />
                  <TextBlock Text="{Binding ProjectReferencesText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.ProjectReferences}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding PackageReferencesText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.PackageReferences}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ExtensionText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.Extension}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SizeBytesText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.Size}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding LastModifiedText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.LastModified}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ChildCountText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.ChildCount}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ReferencedNamespacesText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.ReferencedNamespaces}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ReferencedByText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.ReferencedBy}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding RuleText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.Rule}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SourceText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.Source}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding TargetText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.Target}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding MessageText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.Message}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding FullTypeNameText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.FullTypeName}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding NamespaceText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.NamespaceName}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding FileText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.File}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding BaseTypeText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.BaseType}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ImplementedInterfacesText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.ImplementedInterfaces}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ReferencedTypesText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.ReferencedTypes}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding DependencyMatrixRowText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.MatrixRow}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding DependsOnText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.DependsOn}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding IncomingDependenciesText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.DependencyIncoming}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding DependencyCountText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.DependencyCount}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding CircularDependencyCountText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.CircularDependencyCount}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding ViolationCountText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.ViolationCount}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding LineCountText}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding NodeDetails.LineCount}" TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Grid>

          <GridSplitter Grid.Row="1"
                        x:Name="DiagnosticsSplitter"
                        Height="6"
                        DoubleTapped="DiagnosticsSplitter_OnDoubleTapped"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="#1E293B"
                        ResizeDirection="Rows" />

          <Border Grid.Row="2"
                  BorderBrush="#2E3748"
                  BorderThickness="0,1,0,0"
                  Padding="8"
                  Background="#0B1220">
            <Grid RowDefinitions="Auto,*">
              <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="{Binding DiagnosticsTitleText}" FontWeight="Bold" />
                <Button x:Name="DiagnosticsToggleButton"
                        DockPanel.Dock="Right"
                        Width="24"
                        Height="20"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="▾"
                        Click="DiagnosticsToggleButton_OnClick" />
              </DockPanel>
              <ListBox Grid.Row="1"
                       Margin="0,8,0,0"
                       ItemsSource="{Binding Diagnostics}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Spacing="2" Margin="2">
                      <TextBlock Text="{Binding Severity}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Type}" />
                      <TextBlock Text="{Binding Source}" TextWrapping="Wrap" Foreground="#94A3B8" />
                      <TextBlock Text="{Binding Target}" TextWrapping="Wrap" Foreground="#64748B" />
                      <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>
        </Grid>
        </DockPanel>
      </TabItem>
      <TabItem Header="{Binding SettingsTabText}" FontWeight="SemiBold" Padding="14,8">
        <views:SettingsView />
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
